# Local infrastructure environment reference.
#
# The Phase 0 docker-compose.yml uses hardcoded dev-only defaults (postgres/postgres,
# minioadmin/minioadmin, etc.) so `docker compose up` works with zero configuration.
# This file documents the values services need and the additional secrets that will
# be required by later phases. Copy relevant values into each service's own `.env`
# (see services/*/.env.example) when running a service outside of docker-compose.

# --- Postgres (one database per service) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

USER_SERVICE_DATABASE_URL=postgresql://postgres:postgres@localhost:5433/user_service
LEARNING_MATERIALS_SERVICE_DATABASE_URL=postgresql://postgres:postgres@localhost:5434/learning_materials_service
MEMORY_PROGRESS_SERVICE_DATABASE_URL=postgresql://postgres:postgres@localhost:5435/memory_progress_service
AI_TUTOR_SERVICE_DATABASE_URL=postgresql://postgres:postgres@localhost:5436/ai_tutor_service
NOTIFICATION_SERVICE_DATABASE_URL=postgresql://postgres:postgres@localhost:5437/notification_service

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Kafka ---
KAFKA_BROKERS=localhost:9092

# --- MinIO ---
MINIO_ENDPOINT=localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET_AUDIO=audio
MINIO_BUCKET_ATTACHMENTS=attachments

# --- Kong ---
KONG_PROXY_URL=http://localhost:8000
KONG_ADMIN_URL=http://localhost:8001

# --- AI inference (Phase 3+) ---
INFERENCE_MODE=mock

# --- Clerk (Phase 1) ---
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
CLERK_JWKS_URL=
CLERK_ISSUER=

# --- Novu (Phase 5) ---
NOVU_API_KEY=
