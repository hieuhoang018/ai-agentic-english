# Local infrastructure environment reference.
#
# The Phase 0 docker-compose.yml uses hardcoded dev-only defaults (postgres/postgres,
# minioadmin/minioadmin, etc.) so `docker compose up` works with zero configuration.
# This file documents the values services need and the additional secrets that will
# be required by later phases. Copy relevant values into each service's own `.env`
# (see services/*/.env.example) when running a service outside of docker-compose.

# --- Postgres (one database per service) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

USER_SERVICE_DATABASE_URL=postgresql://postgres:postgres@localhost:5433/user_service
LEARNING_MATERIALS_SERVICE_DATABASE_URL=postgresql://postgres:postgres@localhost:5434/learning_materials_service
NOTIFICATION_SERVICE_DATABASE_URL=postgresql://postgres:postgres@localhost:5437/notification_service

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Kafka ---
KAFKA_BROKERS=localhost:9094

# --- MinIO ---
MINIO_ENDPOINT=localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET_AUDIO=audio
MINIO_BUCKET_ATTACHMENTS=attachments

# --- Kong ---
KONG_PROXY_URL=http://localhost:8000
KONG_ADMIN_URL=http://localhost:8001

# --- Clerk (Phase 1) ---
# Phase 1 runs against a self-signed test RSA keypair + static JWKS
# (TEST_ISSUER/TEST_WEBHOOK_SECRET/TEST_JWKS in
# packages/shared/src/testing/index.ts). docker-compose.yml falls back to
# those stub values when CLERK_WEBHOOK_SECRET/CLERK_ISSUER are unset, so
# these vars can stay empty/unset for local dev with zero configuration.
#
# When a real Clerk app is available: copy this file to infra/.env (gitignored),
# set CLERK_WEBHOOK_SECRET and CLERK_ISSUER to the real Clerk dashboard values,
# and regenerate gateway/kong/kong.yml's consumer/jwt_secrets with the real
# JWKS public key (the public key itself is not a secret and is fine to commit).
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
CLERK_JWKS_URL=
CLERK_ISSUER=

# --- Novu (Phase 5) ---
NOVU_API_KEY=

# --- LLM inference (Groq/OpenRouter live mode — infra/docker-compose.prod.yml) ---
# Required only when running with docker-compose.prod.yml (INFERENCE_MODE=live).
# Groq: https://console.groq.com/keys (free tier, 1000 RPD)
# OpenRouter: https://openrouter.ai/keys (free tier, 50 RPD at $0 balance)
GROQ_API_KEY=
OPENROUTER_API_KEY=

# --- Internal service-to-service secret (infra/docker-compose.prod.yml) ---
# Required when running with docker-compose.prod.yml. The base docker-compose.yml
# hardcodes "dev-internal-secret" for local dev; docker-compose.prod.yml requires
# this var instead (no default) and every consuming service refuses to start if
# it's still "dev-internal-secret" or empty while INFERENCE_MODE=live/DEPLOY_ENV=
# production (see agents/shared/security.py, packages/shared/src/env/index.ts).
# Generate a real value, e.g.: openssl rand -hex 32
INTERNAL_SECRET=
