NEXT_PUBLIC_CLERK_SIGN_IN_URL=/auth/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/auth/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=/main/homepage
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=/main/homepage
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api
API_BASE_URL=http://127.0.0.1:8000/api

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

NEXT_PUBLIC_NOVU_APPLICATION_IDENTIFIER=
# Server-only: same secret as services/notification-service/.env's NOVU_API_KEY.
# Used to HMAC-sign the subscriberId for Novu Inbox secure mode — never expose to the browser.
NOVU_API_KEY=