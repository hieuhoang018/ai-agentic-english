PORT=4005
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/notification_service
REDIS_URL=redis://localhost:6379
KAFKA_BROKERS=localhost:9094

# Service-to-service (docker network hostname in compose; localhost for local dev)
USER_SERVICE_URL=http://localhost:4001
# AGT-07 (Review Agent) reminder context — used by daily-reminder and vocab-of-the-day schedulers
REVIEW_AGENT_URL=http://localhost:8107
INTERNAL_SECRET=dev-internal-secret

# Novu: set NOVU_API_KEY to use the real LiveNovuClient (@novu/api); leave unset to use
# MockNovuClient. No call-site changes needed either way (src/index.ts switches on this var).
NOVU_API_KEY=

# Web Push (VAPID): set all three to use the real web-push sender; leave unset to use
# MockWebPushSender. Generate a keypair once via `npx web-push generate-vapid-keys`.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=
