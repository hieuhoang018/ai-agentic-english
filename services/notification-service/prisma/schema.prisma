generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ProcessedEvent {
  eventId     String   @id
  processedAt DateTime @default(now())
}

model ScheduledReminderRun {
  id           String    @id @default(uuid())
  userId       String
  reminderType String
  runDate      String
  sentAt       DateTime  @default(now())

  @@unique([userId, reminderType, runDate])
}

// `endpoint` is the natural key — a browser has at most one active
// subscription per service worker registration, so re-subscribing (e.g.
// after a key rotation) naturally replaces the row via upsert.
model PushSubscription {
  endpoint    String   @id
  clerkUserId String
  p256dh      String
  auth        String
  createdAt   DateTime @default(now())

  @@index([clerkUserId])
}
