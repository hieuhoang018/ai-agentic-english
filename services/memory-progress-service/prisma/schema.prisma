generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model LearnerModel {
  userId                 String    @id
  currentLevel           Json
  dailyTimeBudgetMinutes Int
  goals                  Json
  weakAreas              Json
  currentStreakDays      Int       @default(0)
  lastActivityDate       DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@map("learner_models")
}

model Progress {
  userId                 String    @id
  pathId                 String
  currentModuleId        String?
  currentLessonId        String?
  currentExerciseId      String?
  completedExerciseIds   Json      @default("[]")
  firstLessonCompletedAt DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@map("progress")
}

model ReviewSchedule {
  id             String    @id @default(uuid())
  userId         String
  itemId         String
  itemType       String
  due            DateTime
  stability      Float
  difficulty     Float
  lastReviewedAt DateTime?
  reps           Int       @default(0)
  lapses         Int       @default(0)
  state          Int       @default(0) // mirrors ts-fsrs State enum (0=New,1=Learning,2=Review,3=Relearning)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([userId, itemId, itemType])
  @@index([userId, due])
  @@map("review_schedules")
}

model Mistake {
  id            String   @id @default(uuid())
  userId        String
  exerciseId    String
  attemptId     String
  errorCategory String
  errorLabel    String
  detail        Json
  createdAt     DateTime @default(now())

  @@index([userId, errorCategory])
  @@map("mistakes")
}

model Attempt {
  id              String   @id @default(uuid())
  userId          String
  exerciseId      String
  submittedAnswer Json
  isCorrect       Boolean?
  score           Float?
  feedback        Json?
  gradedBy        String
  createdAt       DateTime @default(now())

  @@index([userId, exerciseId])
  @@map("attempts")
}

model VocabItem {
  id               String   @id @default(uuid())
  userId           String
  term             String
  meaning          String
  exampleSentence  String?
  sourceExerciseId String?
  createdAt        DateTime @default(now())

  @@index([userId])
  @@map("vocab_items")
}
