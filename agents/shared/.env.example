# AI Agent Layer — Environment Variables
# Copy to .env and fill in values before running agent services.
# All variables have safe defaults for local development (mock mode, local infra).

# ── Agent LTM Database ─────────────────────────────────────────────────────
# Separate from the 5 Node.js service databases (5433-5437)
AGENT_DATABASE_URL=postgresql://postgres:postgres@localhost:5438/agent_ltm

# ── Redis (shared with Node.js services, separate key namespaces) ──────────
REDIS_URL=redis://localhost:6379

# ── Kafka / Redpanda ───────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092

# ── MinIO ──────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ── Groq — Tier 1 LLM + ASR (free, no credit card) ───────────────────────
# LLM: 1,000 requests/day org-level (real-time agents only)
# ASR: 2,000 requests/day, 7,200 audio seconds/hour
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1

# ── OpenRouter — Tier 2 fallback (free, 50 req/day at $0 balance) ─────────
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Ollama — Tier 3 backstop (unlimited, CPU, self-hosted) ────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MAX_LOADED_MODELS=1

# ── LanguageTool — grammar analysis for AGT-04 (self-hosted) ──────────────
# Container-internal URL (host port 8082, container port 8110)
# In docker-compose: http://languagetool:8110/v2
LANGUAGETOOL_URL=http://localhost:8082/v2

# ── Novu — notification delivery (AGT-10 only) ────────────────────────────
NOVU_API_KEY=
NOVU_APP_ID=

# ── Inference mode ─────────────────────────────────────────────────────────
# "mock" — no API keys required, all agents return stubs (default for development)
# "live" — uses Groq/OpenRouter/Ollama for real inference
INFERENCE_MODE=mock
